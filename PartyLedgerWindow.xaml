<Window x:Class="Hale_Marketing_International.PartyLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Party Ledger" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,5">
            <Label Content="Party:" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtPartyName" Width="250" IsReadOnly="True" Margin="5,0"/>
            <Button Content="Select Party" Click="BtnSelectParty_Click" Margin="5,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,5">
            <Label Content="From:" VerticalAlignment="Center"/>
            <DatePicker x:Name="DtFrom" Width="120" Margin="5,0"/>
            <Label Content="To:" VerticalAlignment="Center"/>
            <DatePicker x:Name="DtTo" Width="120" Margin="5,0"/>
            <Button Content="Show Ledger" Click="BtnShowLedger_Click" Margin="10,0"/>
            <Button Content="Print" Click="BtnPrint_Click" Margin="10,0"/>
        </StackPanel>

        <DataGrid x:Name="dgLedger" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="80"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNo}" Width="100"/>
                <DataGridTextColumn Header="Details" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Debit" Binding="{Binding Debit}" Width="80"/>
                <DataGridTextColumn Header="Credit" Binding="{Binding Credit}" Width="80"/>
                <DataGridTextColumn Header="Balance" Binding="{Binding Balance}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
