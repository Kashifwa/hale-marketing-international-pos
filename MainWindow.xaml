<Window x:Class="Hale_Marketing_International.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hale_Marketing_International"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Hale Marketing International - Login"
        Height="600" Width="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Bundled theme: scoped to THIS window only, not App.xaml -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Teal"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.TextBox.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.PasswordBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Local-only brushes for the dark navy/teal side panel -->
            <SolidColorBrush x:Key="NavyDarkBrush" Color="#0B1220"/>
            <SolidColorBrush x:Key="NavyPanelBrush" Color="#101B2D"/>
            <SolidColorBrush x:Key="TealAccentBrush" Color="#14B8A6"/>
            <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA7B8"/>

            <LinearGradientBrush x:Key="NavyGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1220" Offset="0"/>
                <GradientStop Color="#132A3A" Offset="0.55"/>
                <GradientStop Color="#0F3B36" Offset="1"/>
            </LinearGradientBrush>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT: LOGIN FORM ===================== -->
        <Grid Grid.Column="0" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="48,0,48,0">

                <!-- Brand -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,36">
                    <materialDesign:PackIcon Kind="StorefrontOutline" Width="30" Height="30"
                                              Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Hale Marketing" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Sign in" FontSize="30" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock Text="Sign in to continue to your dashboard" FontSize="13"
                           Foreground="Gray" Margin="0,0,0,30"/>

                <TextBlock Text="Username" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBox x:Name="txtUser"
                         materialDesign:HintAssist.Hint="Enter your username"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:TextFieldAssist.LeadingIcon="AccountOutline"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="14" Margin="0,0,0,22" Padding="10,10"/>

                <TextBlock Text="Password" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,10">
                    <PasswordBox x:Name="pwdBox"
                                 materialDesign:HintAssist.Hint="Enter your password"
                                 materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 FontSize="14" Padding="10,10"/>
                    <TextBox x:Name="txtPasswordVisible"
                             materialDesign:HintAssist.Hint="Enter your password"
                             materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14" Padding="10,10" Visibility="Collapsed"/>
                    <Button x:Name="btnEye"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,6,0" Width="30" Height="30"
                            ToolTip="Show / Hide password" Click="BtnEye_Click"
                            Padding="0">
                        <materialDesign:PackIcon Kind="EyeOutline" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <Button x:Name="btnLogin" Content="SIGN IN"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                        Height="44" FontWeight="Bold" Margin="0,28,0,0"
                        Click="BtnLogin_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="KW Soft Solutions" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="  •  Custom POS &amp; Inventory Software" FontSize="11" Foreground="Gray"/>
                </StackPanel>
                <TextBlock Text="📞 0335-2255510" FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="Gray"/>

            </StackPanel>
        </Grid>

        <!-- ===================== RIGHT: DARK BRAND PANEL ===================== -->
        <Border Grid.Column="1" Margin="18" CornerRadius="24" Background="{StaticResource NavyGradientBrush}"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Large watermark icon -->
                <materialDesign:PackIcon Kind="StorefrontOutline"
                                          Width="340" Height="340"
                                          Opacity="0.07" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Top"
                                          Margin="0,-30,0,0"
                                          Grid.RowSpan="2"/>

                <!-- Heading text -->
                <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Margin="48,0,48,32">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <materialDesign:PackIcon Kind="StorefrontOutline" Width="22" Height="22"
                                                  Foreground="{StaticResource TealAccentBrush}"/>
                        <TextBlock Text="Hale Marketing International" FontSize="14" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Welcome back" FontSize="32" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               MaxWidth="420" LineHeight="20">
                        Manage purchases, sales, stock and your full business dashboard
                        from one place. Sign in to pick up right where you left off.
                    </TextBlock>
                </StackPanel>

                <!-- Feature / stat card -->
                <Border Grid.Row="1" Margin="48,0,48,40" Padding="24,20" CornerRadius="16"
                        Background="#1A2C3B">
                    <StackPanel>
                        <TextBlock Text="Everything your business needs" FontSize="16" FontWeight="Bold"
                                   Foreground="White" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14">
                            Real-time stock tracking, sales insights, and purchase
                            management built for growing retail businesses.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource TealAccentBrush}" CornerRadius="12"
                                    Width="26" Height="26" Margin="0,0,-8,0">
                                <materialDesign:PackIcon Kind="ChartLine" Width="14" Height="14"
                                                          Foreground="#0B1220" HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#2E4356" CornerRadius="12" Width="26" Height="26" Margin="10,0,-8,0">
                                <materialDesign:PackIcon Kind="PackageVariantClosed" Width="14" Height="14"
                                                          Foreground="White" HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="#2E4356" CornerRadius="12" Width="26" Height="26" Margin="10,0,0,0">
                                <materialDesign:PackIcon Kind="CashRegister" Width="14" Height="14"
                                                          Foreground="White" HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>
