<Window x:Class="Hale_Marketing_International.PurchaseReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purchase Return — Hale Marketing International"
        Width="1380" Height="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#111D2B"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PosTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ══ TOP BAR ══ -->
        <Border Grid.Row="0" Style="{StaticResource TopBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="3" Height="20" Background="{StaticResource Warning}"
                            CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="PURCHASE RETURN" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TxtPri}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtReturnNo" FontSize="13"
                               Foreground="{StaticResource Warning}" Margin="16,0,0,0"
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <Border x:Name="EditModeBadge" Background="{StaticResource Warning}"
                            CornerRadius="4" Padding="8,3" Margin="12,0,0,0"
                            VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="✎ EDIT MODE" Foreground="#0C1520" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="＋ Add Item"  Style="{StaticResource BtnPrimary}" Margin="4,0" Click="BtnAddProduct_Click"/>
                    <Button Content="📋 Returns"   Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnShowReturnList_Click"/>
                    <Button Content="💾 Save"      Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnSaveReturn_Click"/>
                    <Button Content="🖨 Print"     Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnPrint_Click"/>
                    <Button Content="⟳ New"       Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnClear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="1" Style="{StaticResource SectionPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="RETURN NO"                        Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="2" Text="DATE"                             Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="4" Text="SUPPLIER  (ID shown in list)"     Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="6" Text="PHONE"                            Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="8" Text="ADDRESS"                          Style="{StaticResource FieldLabel}"/>

                <TextBox    x:Name="TxtReturnNoBox" Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource PosInput}" IsReadOnly="True"/>
                <DatePicker x:Name="DtReturnDate"   Grid.Row="1" Grid.Column="2"
                            Style="{StaticResource PosDate}"/>

                <!-- Supplier search popup -->
                <Grid Grid.Row="1" Grid.Column="4">
                    <TextBox x:Name="TxtPartySearch"
                             Style="{StaticResource PosInput}"
                             Text="Search supplier by name or ID..."
                             GotFocus="TxtPartySearch_GotFocus"
                             LostFocus="TxtPartySearch_LostFocus"
                             TextChanged="TxtPartySearch_TextChanged"
                             KeyDown="TxtPartySearch_KeyDown"/>
                    <Popup x:Name="PartyPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=TxtPartySearch}"
                           StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#1C2A3A" BorderBrush="#FFB300"
                                BorderThickness="1" CornerRadius="0,0,4,4"
                                MaxHeight="240" MinWidth="340">
                            <ListBox x:Name="PartyList" Background="Transparent"
                                     BorderThickness="0" Foreground="White" FontSize="12"
                                     MouseLeftButtonUp="PartyList_MouseUp"
                                     KeyDown="PartyList_KeyDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,2">
                                            <Border Background="#2A1F00" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding IdLabel}" Foreground="#FFB300" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" Foreground="#E8F0F7" VerticalAlignment="Center"/>
                                            <Border Background="#1A1200" CornerRadius="3" Padding="5,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding TypeLabel}" Foreground="#6B8FA8" FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"    Value="8,5"/>
                                        <Setter Property="Cursor"     Value="Hand"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D3800"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected"  Value="True">
                                                <Setter Property="Background" Value="#FFB300"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <TextBox x:Name="TxtSupplierPhone"   Grid.Row="1" Grid.Column="6"
                         Style="{StaticResource PosInput}" IsReadOnly="True"/>
                <TextBox x:Name="TxtSupplierAddress" Grid.Row="1" Grid.Column="8"
                         Style="{StaticResource PosInput}" IsReadOnly="True"/>
            </Grid>
        </Border>

        <!-- ══ PRODUCT ENTRY ══ -->
        <Border Grid.Row="2" Background="#0C1520"
                BorderBrush="{StaticResource Border0}" BorderThickness="0,0,0,1"
                Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="144"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Labels -->
                <TextBlock Grid.Column="0"  Text="SEARCH PRODUCT"  Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="2"  Text="CODE"            Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="4"  Text="COMPANY"         Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="6"  Text="RATE"            Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="10" Text="RETURN QTY"      Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="12" Text="DETAILS / NOTES" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="14" Text="ATTACHMENT"      Style="{StaticResource FieldLabel}"/>

                <!-- Search + popup -->
                <Grid Grid.Row="1" Grid.Column="0">
                    <TextBox x:Name="TxtSearch" Style="{StaticResource PosInput}"
                             Text="Type to search..."
                             TextChanged="TxtSearch_TextChanged"
                             GotFocus="TxtSearch_GotFocus"
                             LostFocus="TxtSearch_LostFocus"
                             KeyDown="TxtSearch_KeyDown"/>
                    <Popup x:Name="ProductPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=TxtSearch}"
                           StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#1C2A3A" BorderBrush="#FFB300"
                                BorderThickness="1" CornerRadius="0,0,4,4"
                                MaxHeight="220" MinWidth="300">
                            <ListBox x:Name="ProductList" Background="Transparent"
                                     BorderThickness="0" Foreground="White" FontSize="12"
                                     MouseLeftButtonUp="ProductList_MouseUp"
                                     KeyDown="ProductList_KeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"    Value="10,7"/>
                                        <Setter Property="Cursor"     Value="Hand"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#E8F0F7"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D3800"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected"  Value="True">
                                                <Setter Property="Background" Value="#FFB300"/>
                                                <Setter Property="Foreground" Value="#0C1520"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <TextBox x:Name="TxtProductCode" Grid.Row="1" Grid.Column="2"  Style="{StaticResource PosInput}" IsReadOnly="True"/>
                <TextBox x:Name="TxtCompany"     Grid.Row="1" Grid.Column="4"  Style="{StaticResource PosInput}" IsReadOnly="True"/>
                <TextBox x:Name="TxtRate"        Grid.Row="1" Grid.Column="6"  Style="{StaticResource PosInput}" IsReadOnly="False"/>
                
                <TextBox x:Name="TxtReturnQty"   Grid.Row="1" Grid.Column="10" Style="{StaticResource PosInput}" KeyDown="TxtReturnQty_KeyDown"/>
                <TextBox x:Name="TxtDetails"     Grid.Row="1" Grid.Column="12" Style="{StaticResource PosInput}"
                         Text="Optional details..."
                         GotFocus="TxtDetails_GotFocus" LostFocus="TxtDetails_LostFocus"/>
                <TextBox x:Name="TxtProductName" Visibility="Collapsed"/>

                <!-- Attach -->
                <Grid Grid.Row="1" Grid.Column="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnAttach" Content="📎 Attach" Style="{StaticResource BtnGhost}"
                            Height="34" FontSize="11" Click="BtnAttach_Click"/>
                    <Button x:Name="BtnClearAttach" Grid.Column="2" Content="✕" Height="34" Width="34"
                            Style="{StaticResource BtnDanger}" FontSize="11" Padding="0"
                            Click="BtnClearAttach_Click" Visibility="Collapsed"
                            ToolTip="Remove attachment"/>
                </Grid>
                <TextBlock x:Name="TxtAttachHint" Grid.Row="2" Grid.Column="12" Grid.ColumnSpan="3"
                           Foreground="{StaticResource Warning}" FontSize="10" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>

                <!-- Row-edit hint -->
                <Border x:Name="RowEditHint" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="11"
                        Background="#1A1200" CornerRadius="3" Padding="8,3" Margin="0,4,0,0"
                        Visibility="Collapsed">
                    <TextBlock Foreground="#FFB300" FontSize="10"
                               Text="✎ Editing row — change values above then click ＋ Add Item to update"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══ DATAGRID ══ -->
        <DataGrid x:Name="ReturnDataGrid" Grid.Row="3"
                  Style="{StaticResource PosGrid}"
                  ColumnHeaderStyle="{StaticResource PosGridHeader}"
                  RowStyle="{StaticResource PosGridRow}"
                  CellStyle="{StaticResource PosGridCell}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"            Binding="{Binding Index}"          Width="44"/>
                <DataGridTextColumn Header="CODE"         Binding="{Binding ProductCode}"    Width="90"/>
                <DataGridTextColumn Header="PRODUCT NAME" Binding="{Binding ProductName}"    Width="*"/>
                <DataGridTextColumn Header="COMPANY"      Binding="{Binding Company}"        Width="120"/>
                <DataGridTextColumn Header="DETAILS"      Binding="{Binding Details}"        Width="130"/>
                <DataGridTextColumn Header="RATE"         Binding="{Binding Rate,            StringFormat=N2}" Width="90"/>
                <DataGridTextColumn Header="RETURN QTY"   Binding="{Binding ReturnQuantity}" Width="90"/>
                <DataGridTextColumn Header="AMOUNT"       Binding="{Binding Amount,          StringFormat=N2}" Width="110"/>
                <DataGridTemplateColumn Header="📎" Width="74">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding AttachLabel}" Tag="{Binding Index}"
                                    Height="24" FontSize="11" Background="Transparent"
                                    BorderBrush="#FFB300" BorderThickness="1"
                                    Foreground="#FFB300" Cursor="Hand" Padding="4,0"
                                    Click="BtnOpenAttach_Click"
                                    Visibility="{Binding HasAttachment, Converter={StaticResource BoolToVisibility}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Row edit -->
                <DataGridTemplateColumn Header="✎" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✎ Edit" Tag="{Binding Index}"
                                    Height="24" FontSize="10" Background="Transparent"
                                    BorderBrush="#FFB300" BorderThickness="1"
                                    Foreground="#FFB300" Cursor="Hand" Padding="4,0"
                                    Click="BtnEditRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕ Del" Tag="{Binding Index}"
                                    Style="{StaticResource BtnInlineDel}"
                                    Click="BtnDeleteItem_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ══ TOTALS ══ -->
        <Border Grid.Row="4" Style="{StaticResource TotalsPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource Bg3}" CornerRadius="4" Padding="12,6">
                        <StackPanel>
                            <TextBlock Text="ITEMS" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="TxtItemsCount" Text="0"
                                       Foreground="{StaticResource TxtPri}" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="SUBTOTAL"   Style="{StaticResource FieldLabel}" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Row="2" Text="NET AMOUNT" Style="{StaticResource FieldLabel}" HorizontalAlignment="Right"
                               Foreground="{StaticResource Warning}" FontSize="11"/>
                    <TextBox x:Name="TxtSubtotal" Grid.Row="0" Grid.Column="2"
                             Style="{StaticResource PosInput}" IsReadOnly="True" Text="0.00"/>
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                            Background="#1A1200" CornerRadius="4" Padding="10,6"
                            BorderBrush="{StaticResource Warning}" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="NET AMOUNT" Foreground="{StaticResource Warning}"
                                       FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtNetAmount" Text="0.00" HorizontalAlignment="Right"
                                       Foreground="{StaticResource Warning}" FontSize="18" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="5" Background="{StaticResource Bg0}" Padding="18,0">
            <TextBlock Text="Hale Marketing International — Purchase Return"
                       Foreground="{StaticResource TxtMuted}" FontSize="10" VerticalAlignment="Center"/>
        </Border>

        <!-- ══ SAVED RETURNS SIDE PANEL ══ -->
        <Border x:Name="BorderReturnList" Grid.Row="0" Grid.RowSpan="6"
                HorizontalAlignment="Right" Width="440"
                Background="#0C1520" BorderBrush="#FFB300" BorderThickness="1,0,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#141F2B" Padding="12,0">
                    <Grid>
                        <TextBlock Text="PURCHASE RETURNS" FontWeight="Bold" FontSize="12"
                                   Foreground="{StaticResource Warning}" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" Width="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TxtMuted}"
                                Click="BtnCloseReturnList_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#111D2B" Padding="8,6">
                    <StackPanel>
                        <TextBox x:Name="TxtRetListSearch" Style="{StaticResource PosInput}"
                                 Text="Search return / supplier..."
                                 GotFocus="TxtRetListSearch_GotFocus"
                                 LostFocus="TxtRetListSearch_LostFocus"
                                 TextChanged="TxtRetListSearch_TextChanged"
                                 Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker x:Name="DtRetListFrom" Style="{StaticResource PosDate}" Width="120" Margin="0,0,6,0"/>
                            <DatePicker x:Name="DtRetListTo"   Style="{StaticResource PosDate}" Width="120" Margin="0,0,6,0"/>
                            <Button Content="🔍" Style="{StaticResource BtnPrimary}" Width="40" Click="BtnRetListFilter_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="DgReturnList" Grid.Row="2"
                          Style="{StaticResource PosGrid}"
                          ColumnHeaderStyle="{StaticResource PosGridHeader}"
                          RowStyle="{StaticResource PosGridRow}"
                          CellStyle="{StaticResource PosGridCell}"
                          SelectionChanged="DgReturnList_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RET #"    Binding="{Binding ReturnNo}"                   Width="90"/>
                        <DataGridTextColumn Header="DATE"     Binding="{Binding Date}"                       Width="80"/>
                        <DataGridTextColumn Header="SUPPLIER" Binding="{Binding PartyName}"                  Width="*"/>
                        <DataGridTextColumn Header="AMOUNT"   Binding="{Binding NetTotal, StringFormat=N2}"  Width="85"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="3" Background="#141F2B" Padding="8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnEditReturn"   Content="✎ Load &amp; Edit" Style="{StaticResource BtnGhost}"  Margin="0,0,6,0" Width="120" Click="BtnEditReturn_Click"   IsEnabled="False"/>
                        <Button x:Name="BtnDeleteReturn" Content="🗑 Delete"          Style="{StaticResource BtnDanger}" Width="90"       Click="BtnDeleteReturn_Click" IsEnabled="False"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
