<!--
    RestoreWindow.xaml
    Shown on the LOGIN SCREEN when no local DB is found.
    User signs in with Google → app finds their backups → restores automatically.
    No master key needed — encryption key is derived from their Google email.
-->
<Window x:Class="Hale_Marketing_International.Views.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore Data from Google Drive"
        Width="460" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2C6FDF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A5BC8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Restore Data from Google Drive"
                   FontSize="19" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="Sign in with the same Google account you used on your previous device. Your data will be restored automatically."
                   TextWrapping="Wrap" FontSize="12" Foreground="#777" Margin="0,0,0,20"/>

        <!-- Step 1: Sign in -->
        <Border Grid.Row="2" Background="#F0F4FF" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Background="#2C6FDF" CornerRadius="10" Width="22" Height="22" Margin="0,0,8,0">
                    <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Sign in with Google" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,16">
            <Button x:Name="BtnSignIn" Content="Sign in with Google"
                    Style="{StaticResource PrimaryBtn}" Width="200"
                    Click="BtnSignIn_Click"/>
            <TextBlock x:Name="TxtSignInStatus" Text="" Margin="12,0,0,0"
                       VerticalAlignment="Center" FontSize="12"
                       Foreground="#2E7D32" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Step 2: Select backup -->
        <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Padding="4">
            <Grid>
                <TextBlock x:Name="TxtNoBackups"
                           Text="Sign in to see your available backups."
                           FontSize="12" Foreground="#999"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ListBox x:Name="LstBackups"
                         BorderThickness="0" FontSize="13"
                         IsEnabled="False" Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Padding="6,5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Progress -->
        <ProgressBar Grid.Row="5" x:Name="PbRestore"
                     Height="5" Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed" Margin="0,10,0,4"
                     Foreground="#2C6FDF"/>

        <!-- Status -->
        <TextBlock Grid.Row="6" x:Name="TxtStatus"
                   FontSize="12" Foreground="#555"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Text=""/>

        <!-- Restore button -->
        <Button Grid.Row="8" x:Name="BtnRestore"
                Content="✅ Restore Selected Backup"
                Style="{StaticResource PrimaryBtn}"
                IsEnabled="False" HorizontalAlignment="Stretch"
                Click="BtnRestore_Click"/>
    </Grid>
</Window>
