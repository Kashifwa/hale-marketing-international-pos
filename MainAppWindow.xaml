<Window x:Class="Hale_Marketing_International.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hale_Marketing_International"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Hale Marketing International - Dashboard"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Left" Margin="8" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1ABC9C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F2F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Background="#2C3E50" Grid.Row="0" Grid.ColumnSpan="2" Padding="10">
            <DockPanel>
                <TextBlock Text="Hale Marketing International"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

                <Button x:Name="btnLogout"
                    Content="Logout"
                    Foreground="White"
                    Background="#E74C3C"
                    Padding="8,3"
                    Margin="5"
                    Click="Logout_Click"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- SIDEBAR WITH SCROLL -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Background="#34495E" Margin="10,0,0,0">
                <TextBlock Text="Navigation" Foreground="White" FontSize="16" Margin="5" FontWeight="Bold"/>
                <Button Content="➕ Add Party" Style="{StaticResource SidebarBtn}" Click="BtnAddParty_Click"/>
                <Button Content="Stocks" Style="{StaticResource SidebarBtn}" Click="Stock_Click"/>
                <Button Content="Ledger" Style="{StaticResource SidebarBtn}" Click="CompanyLedger_Click"/>
                <Button Content="Items" Style="{StaticResource SidebarBtn}" Click="Products_Click"/>
                <Button Content="Sales File" Style="{StaticResource SidebarBtn}" Click="SaleFile_Click"/>
                <Button Content="Purchase File" Style="{StaticResource SidebarBtn}" Click="PurchaseFile_Click"/>
                <Button Content="Sales Return" Style="{StaticResource SidebarBtn}" Click="SalesReturn_Click"/>
                <Button Content="Purchase Return" Style="{StaticResource SidebarBtn}" Click="PurchaseReturn_Click"/>
                <Button Content="Payemnt Receipt" Style="{StaticResource SidebarBtn}" Click="PaymentReceipt_Click"/>
                <Button Content="Cash Receipt" Style="{StaticResource SidebarBtn}" Click="CashReceipt_Click"/>
                <Button Content="Party Ledger" Style="{StaticResource SidebarBtn}" Click="Ledger_Click"/>
                <Button Content="Item Ledger" Style="{StaticResource SidebarBtn}" Click="ItemLedger_Click"/>
                
                
            </StackPanel>
        </ScrollViewer>

        <!-- MAIN CONTENT WITH SCROLL -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid x:Name="MainContent" Background="#FFFFFF" Margin="30">
                <StackPanel HorizontalAlignment="Right"
                 VerticalAlignment="Top">
                    <Button Content="☁ Backup &amp; Sync" Style="{StaticResource SidebarBtn}" Click="BackupSync_Click"/>
                </StackPanel>           
                <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center">
                    <Grid Margin="10">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="320"/>
                        </Grid.RowDefinitions>

                        <!-- KPI -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <Border Background="#1ABC9C" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Sales"/>
                                    <TextBlock Text="{Binding TodaySales}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#3498DB" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Profit"/>
                                    <TextBlock Text="{Binding Profit}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#E74C3C" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Low Stock"/>
                                    <TextBlock Text="{Binding LowStock}"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- AI INSIGHTS -->
                        <StackPanel Grid.Row="1" Margin="10">
                            <TextBlock Text="{Binding SalesInsight}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding FastMoving}"/>
                            <TextBlock Text="{Binding StockInsight}"/>
                            <TextBlock Text="{Binding Prediction}"/>
                        </StackPanel>

                        <!-- CHARTS -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <lvc:CartesianChart Grid.Column="0"
                                Height="300" Width="380"
                                Series="{Binding SalesSeries}" />

                            <lvc:CartesianChart Grid.Column="1"
                                Height="300" Width="380"
                                Series="{Binding TopSeries}" />
                        </Grid>
                    </Grid>
                    <!-- This line centers vertically -->

                    <TextBlock Text="Welcome to Hale Marketing Internationals"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>


                </StackPanel>
                <!-- Footer -->
                  
            </Grid>


        </ScrollViewer>

    </Grid>
</Window>
