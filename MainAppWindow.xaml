<Window x:Class="Hale_Marketing_International.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hale_Marketing_International"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Hale Marketing International - Dashboard"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- Sidebar nav button style -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B8C4D9"/>
            <Setter Property="Margin" Value="12,3"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active/Dashboard nav item look -->
        <Style x:Key="SidebarBtnActive" TargetType="Border">
            <Setter Property="Background" Value="#2F6FED"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="12,3"/>
            <Setter Property="Padding" Value="14,11"/>
        </Style>

        <!-- White card style used across dashboard -->
        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.10" Color="#1C2B45"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Colored icon badge used on KPI cards -->
        <Style x:Key="IconBadge" TargetType="Border">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

    </Window.Resources>

    <Grid Background="#F3F5F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= SIDEBAR (full height) ================= -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="#101B33">
            <DockPanel LastChildFill="True">

                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="18,20,10,20">
                    <materialDesign:PackIcon Kind="StorefrontOutline" Width="26" Height="26" Foreground="#2F6FED" VerticalAlignment="Center"/>
                    <TextBlock Text="HMI POS" Foreground="White" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Bottom item: Backup & Sync (keeps BackupSync_Click) -->
                <Button x:Name="btnBackupSync" DockPanel.Dock="Bottom" Style="{StaticResource SidebarBtn}" Click="BackupSync_Click" Margin="12,10,12,20">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudSyncOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Backup &amp; Sync" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Nav list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,10">

                        <!-- Dashboard: static active item (this window) -->
                        <Border Style="{StaticResource SidebarBtnActive}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="20" Height="20" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" Foreground="White" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Style="{StaticResource SidebarBtn}" Click="BtnAddParty_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlusOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Add Party" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="Stock_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Stocks" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="CompanyLedger_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Ledger" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="Products_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Items" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="SaleFile_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CartOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Sales File" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="PurchaseFile_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TruckDeliveryOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Purchase File" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="SalesReturn_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="KeyboardReturn" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Sales Return" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="PurchaseReturn_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowULeftBottom" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Purchase Return" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="PaymentReceipt_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CreditCardOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Payment Receipt" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="CashReceipt_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashMultiple" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Cash Receipt" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="Ledger_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountCashOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Party Ledger" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarBtn}" Click="ItemLedger_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FormatListBulleted" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Item Ledger" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ================= TOP WHITE HEADER (content area only) ================= -->
        <Border Grid.Row="0" Grid.Column="1" Background="White" BorderBrush="#E7EAF0" BorderThickness="0,0,0,1">
            <DockPanel Margin="28,0" VerticalAlignment="Center">

                <TextBlock Text="Dashboard" FontSize="22" FontWeight="Bold" Foreground="#101B33" DockPanel.Dock="Left" VerticalAlignment="Center"/>

                <!-- Right side: notification bell + admin dropdown -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">

                    <!-- Notification bell (decorative) -->
                    <Border Width="38" Height="38" CornerRadius="19" Background="#F3F5F9" Margin="0,0,10,0">
                        <materialDesign:PackIcon Kind="BellOutline" Width="18" Height="18" Foreground="#5A6376" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Admin avatar + dropdown -->
                    <ToggleButton x:Name="toggleAdminMenu" Style="{x:Null}" Cursor="Hand"
                                  VerticalAlignment="Center">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="34" Height="34" CornerRadius="17" Background="#2F6FED">
                                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Admin" Margin="8,0,4,0" VerticalAlignment="Center" Foreground="#101B33" FontWeight="SemiBold"/>
                                        <materialDesign:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#8B94A6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <Popup PlacementTarget="{Binding ElementName=toggleAdminMenu}"
                           IsOpen="{Binding IsChecked, ElementName=toggleAdminMenu}"
                           StaysOpen="False"
                           Placement="Bottom"
                           HorizontalOffset="-40"
                           VerticalOffset="8">
                        <Border Background="White" CornerRadius="8" Padding="6" MinWidth="140">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.18" Color="#1C2B45"/>
                            </Border.Effect>
                            <StackPanel>
                                <Button x:Name="btnLogout"
                                        Content="Logout"
                                        Click="Logout_Click"
                                        Background="Transparent"
                                        Foreground="#E74C3C"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Left"
                                        Padding="12,8"
                                        Width="Auto" Height="Auto"
                                        HorizontalAlignment="Stretch"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="lb" Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="lb" Property="Background" Value="#FDECEC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>

                </StackPanel>

                <!-- Search box -->
                <Border Background="#F3F5F9" CornerRadius="8" Padding="10,7" Width="320" HorizontalAlignment="Left" Margin="30,0,0,0">
                    <DockPanel>
                        <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Foreground="#8B94A6" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtGlobalSearch" Background="Transparent" BorderThickness="0" Margin="8,0,0,0"
                                 Foreground="#101B33" VerticalAlignment="Center" Tag="Search anything..."/>
                    </DockPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- ================= MAIN CONTENT ================= -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="MainContent" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="380"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: KPI CARDS -->
                <UniformGrid Grid.Row="0" Rows="1" Columns="3">

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource IconBadge}" Background="#E7F0FF">
                                <materialDesign:PackIcon Kind="CartOutline" Width="24" Height="24" Foreground="#2F6FED" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="TOTAL SALES" FontSize="11" Foreground="#8B94A6" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TodaySales}" FontSize="20" FontWeight="Bold" Foreground="#101B33"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource IconBadge}" Background="#E6F9F1">
                                <materialDesign:PackIcon Kind="TrendingUp" Width="24" Height="24" Foreground="#1ABC9C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="PROFIT" FontSize="11" Foreground="#8B94A6" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Profit}" FontSize="20" FontWeight="Bold" Foreground="#101B33"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource IconBadge}" Background="#FDECEC">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="24" Height="24" Foreground="#E74C3C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="LOW STOCK" FontSize="11" Foreground="#8B94A6" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding LowStock}" FontSize="20" FontWeight="Bold" Foreground="#101B33"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- ROW 1: AI INSIGHTS -->
                <Border Grid.Row="1" Style="{StaticResource DashCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="LightbulbOnOutline" Width="20" Height="20" Foreground="#2F6FED" VerticalAlignment="Center"/>
                            <TextBlock Text="AI Insights" FontWeight="Bold" FontSize="15" Margin="8,0,0,0" Foreground="#101B33"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SalesInsight}" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,2"/>
                        <TextBlock Text="{Binding FastMoving}" Foreground="#5A6376" Margin="0,2"/>
                        <TextBlock Text="{Binding StockInsight}" Foreground="#5A6376" Margin="0,2"/>
                        <TextBlock Text="{Binding Prediction}" Foreground="#5A6376" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <!-- ROW 2: CHARTS -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource DashCard}">
                        <DockPanel>
                            <TextBlock Text="Sales Overview" FontWeight="Bold" FontSize="15" Foreground="#101B33" DockPanel.Dock="Top" Margin="0,0,0,10"/>
                            <lvc:CartesianChart Series="{Binding SalesSeries}" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource DashCard}">
                        <DockPanel>
                            <TextBlock Text="Top Selling Items" FontWeight="Bold" FontSize="15" Foreground="#101B33" DockPanel.Dock="Top" Margin="0,0,0,10"/>
                            <lvc:PieChart Series="{Binding TopSeries}" />
                        </DockPanel>
                    </Border>

                </Grid>

                <!-- ROW 3: BOTTOM STAT ROW -->
                <UniformGrid Grid.Row="3" Rows="1" Columns="4" Margin="0,4,0,0">

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel>
                            <TextBlock Text="TOTAL PRODUCTS" FontSize="11" Foreground="#8B94A6" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalProducts}" FontSize="22" FontWeight="Bold" Foreground="#101B33" Margin="0,4,0,0"/>
                            <TextBlock Text="Items" FontSize="11" Foreground="#8B94A6"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel>
                            <TextBlock Text="LOW STOCK ITEMS" FontSize="11" Foreground="#E74C3C" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding LowStock}" FontSize="22" FontWeight="Bold" Foreground="#E74C3C" Margin="0,4,0,0"/>
                            <TextBlock Text="Items" FontSize="11" Foreground="#8B94A6"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel>
                            <TextBlock Text="TOTAL PARTIES" FontSize="11" Foreground="#8B94A6" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalParties}" FontSize="22" FontWeight="Bold" Foreground="#101B33" Margin="0,4,0,0"/>
                            <TextBlock Text="Parties" FontSize="11" Foreground="#8B94A6"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashCard}">
                        <StackPanel>
                            <TextBlock Text="DUE AMOUNT" FontSize="11" Foreground="#8B94A6" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DueAmount}" FontSize="22" FontWeight="Bold" Foreground="#101B33" Margin="0,4,0,0"/>
                            <TextBlock Text="Total" FontSize="11" Foreground="#8B94A6"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

            </Grid>
        </ScrollViewer>

    </Grid>
</Window>
