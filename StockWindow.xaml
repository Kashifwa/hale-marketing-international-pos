<Window x:Class="Hale_Marketing_International.StockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock Report — Hale Marketing International"
        Width="1300" Height="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#111D2B"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PosTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Style="{StaticResource TopBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="3" Height="20" Background="{StaticResource Accent}"
                            CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="STOCK REPORT" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TxtPri}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStockCount" Text="  •  0 products"
                               FontSize="12" Foreground="{StaticResource TxtMuted}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Search bar -->
                <Border Grid.Column="1" Background="{StaticResource Bg3}" CornerRadius="4"
                        BorderBrush="{StaticResource Border0}" BorderThickness="1"
                        Width="360" HorizontalAlignment="Center" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⌕" Foreground="{StaticResource TxtMuted}" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtSearch" Grid.Column="1"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TxtMuted}"
                                 CaretBrush="{StaticResource Accent}"
                                 FontSize="13" Padding="0"
                                 VerticalAlignment="Center" VerticalContentAlignment="Center"
                                 Text="Search by product / code / company..."
                                 TextChanged="TxtSearch_TextChanged"
                                 GotFocus="TxtSearch_GotFocus"
                                 LostFocus="TxtSearch_LostFocus"/>
                        <Button x:Name="BtnClearSearch" Grid.Column="2"
                                Content="✕" Width="28" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource TxtMuted}"
                                FontSize="11" Cursor="Hand" Margin="0,0,4,0"
                                Click="BtnClearSearch_Click"
                                Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⟳ Refresh" Style="{StaticResource BtnPrimary}" Margin="4,0" Click="BtnRefresh_Click"/>
                    <Button Content="🖨 Print"   Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnPrint_Click"/>
                    <Button Content="Close"       Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="1" Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Border0}" BorderThickness="0,0,0,1"
                Padding="18,8">
            <StackPanel Orientation="Horizontal">
                <!-- Company filter -->
                <TextBlock Text="COMPANY" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbCompanyFilter" Style="{StaticResource PosCombo}"
                          Width="180" Margin="0,0,16,0"
                          SelectionChanged="CmbCompanyFilter_SelectionChanged"/>

                <!-- Stock filter -->
                <TextBlock Text="STOCK STATUS" Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbStockFilter" Style="{StaticResource PosCombo}"
                          Width="150" Margin="0,0,16,0"
                          SelectionChanged="CmbStockFilter_SelectionChanged">
                    <ComboBoxItem IsSelected="True">All Items</ComboBoxItem>
                    <ComboBoxItem>In Stock</ComboBoxItem>
                    <ComboBoxItem>Out of Stock</ComboBoxItem>
                    <ComboBoxItem>Low Stock (≤5)</ComboBoxItem>
                </ComboBox>

                <!-- Summary badges -->
                <Border Background="{StaticResource AccentDim}" CornerRadius="4"
                        Padding="10,4" Margin="16,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Items: " Foreground="{StaticResource TxtMuted}" FontSize="11"/>
                        <TextBlock x:Name="TxtTotalItems" Text="0"
                                   Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#1A1200" CornerRadius="4"
                        BorderBrush="{StaticResource Warning}" BorderThickness="1"
                        Padding="10,4" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Stock Value: " Foreground="{StaticResource TxtMuted}" FontSize="11"/>
                        <TextBlock x:Name="TxtTotalValue" Text="0.00"
                                   Foreground="{StaticResource Warning}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#1A0A0A" CornerRadius="4"
                        BorderBrush="{StaticResource Danger}" BorderThickness="1"
                        Padding="10,4" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Out of Stock: " Foreground="{StaticResource TxtMuted}" FontSize="11"/>
                        <TextBlock x:Name="TxtOutOfStock" Text="0"
                                   Foreground="{StaticResource Danger}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- DATA GRID -->
        <DataGrid x:Name="StockGrid"
                  Grid.Row="2"
                  Style="{StaticResource PosGrid}"
                  ColumnHeaderStyle="{StaticResource PosGridHeader}"
                
                  CellStyle="{StaticResource PosGridCell}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"             Binding="{Binding RowNum}"         Width="44"/>
                <DataGridTextColumn Header="CODE"          Binding="{Binding Code}"            Width="90"/>
                <DataGridTextColumn Header="PRODUCT NAME"  Binding="{Binding ProductName}"     Width="*"/>
                <DataGridTextColumn Header="COMPANY"       Binding="{Binding Company}"         Width="130"/>
                <DataGridTextColumn Header="PURCHASE PRICE" Binding="{Binding PurchasePrice, StringFormat=N2}" Width="115"/>
                <DataGridTextColumn Header="SALE PRICE"    Binding="{Binding SalePrice, StringFormat=N2}"    Width="100"/>
                <DataGridTextColumn Header="PURCHASED"     Binding="{Binding TotalPurchased}"  Width="90"/>
                <DataGridTextColumn Header="SOLD"          Binding="{Binding TotalSold}"       Width="70"/>
                <DataGridTextColumn Header="RTN IN"        Binding="{Binding ReturnIn}"        Width="70"/>
                <DataGridTextColumn Header="RTN OUT"       Binding="{Binding ReturnOut}"       Width="70"/>
                <!-- Current Stock with color indicator -->
                <DataGridTemplateColumn Header="CURRENT QTY" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Center"
                                    Background="{Binding StockBackground}">
                                <TextBlock Text="{Binding CurrentStock}"
                                           Foreground="{Binding StockForeground}"
                                           FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="STOCK VALUE"   Binding="{Binding StockValue, StringFormat=N2}" Width="110"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource PosGridRow}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                            <Setter Property="Background" Value="#1A0505"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                            <Setter Property="Background" Value="#1A1200"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- TOTALS FOOTER -->
        <Border Grid.Row="3" Style="{StaticResource TotalsPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Legend -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1A0505" CornerRadius="3" Padding="8,3" Margin="0,0,8,0"
                            BorderBrush="{StaticResource Danger}" BorderThickness="1">
                        <TextBlock Text="● Out of Stock (Qty = 0)" Foreground="{StaticResource Danger}" FontSize="11"/>
                    </Border>
                    <Border Background="#1A1200" CornerRadius="3" Padding="8,3" Margin="0,0,8,0"
                            BorderBrush="{StaticResource Warning}" BorderThickness="1">
                        <TextBlock Text="● Low Stock (Qty ≤ 5)" Foreground="{StaticResource Warning}" FontSize="11"/>
                    </Border>
                    <Border Background="{StaticResource AccentDim}" CornerRadius="3" Padding="8,3"
                            BorderBrush="{StaticResource Accent}" BorderThickness="1">
                        <TextBlock Text="● In Stock" Foreground="{StaticResource Accent}" FontSize="11"/>
                    </Border>
                </StackPanel>

                <!-- Grand totals -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource Bg3}" CornerRadius="4" Padding="14,6" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="PRODUCTS SHOWN" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="TxtShownCount" Text="0"
                                       Foreground="{StaticResource TxtPri}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Bg3}" CornerRadius="4" Padding="14,6" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL UNITS" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="TxtTotalUnits" Text="0"
                                       Foreground="{StaticResource TxtPri}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A1200" CornerRadius="4" Padding="14,6"
                            BorderBrush="{StaticResource Warning}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="TOTAL STOCK VALUE" Style="{StaticResource SectionTitle}"
                                       Foreground="{StaticResource Warning}"/>
                            <TextBlock x:Name="TxtGrandValue" Text="0.00"
                                       Foreground="{StaticResource Warning}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="4" Background="{StaticResource Bg0}" Padding="18,0">
            <Grid>
                <TextBlock x:Name="TxtStatus" Text="Ready"
                           Foreground="{StaticResource TxtMuted}" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="Hale Marketing International — Stock Report"
                           Foreground="{StaticResource Border0}" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>