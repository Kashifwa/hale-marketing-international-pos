<!--
    AdminCreationWindow.xaml
    Opened by Ctrl+Shift+A from the login screen.
    Creates login credentials ONLY — no master key, no Google setup here.
    Google Drive is connected separately inside the app after login.
-->
<Window x:Class="Hale_Marketing_International.AdminCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Admin Account"
        Width="400" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Create Admin Account"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="Create your login credentials. You can connect Google Drive for backup from inside the app after logging in."
                   TextWrapping="Wrap" FontSize="12" Foreground="#777" Margin="0,0,0,18"/>

        <TextBlock Grid.Row="2" Text="Username" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="TxtUsername"
                 Height="36" Padding="8,6" FontSize="13"
                 BorderBrush="#CCCCCC" BorderThickness="1"
                 Margin="0,0,0,12" MaxLength="50"/>

        <TextBlock Grid.Row="4" Text="Password" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="5" x:Name="PbPassword"
                     Height="36" Padding="8,6" FontSize="13"
                     BorderBrush="#CCCCCC" BorderThickness="1"/>

        <Button Grid.Row="7" x:Name="BtnCreate"
                Content="Sign Up"
                Height="40" Background="#2C6FDF" Foreground="White"
                FontSize="14" FontWeight="SemiBold"
                BorderThickness="0" Margin="100,0,0,50"
                Click="BtnCreate_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A5BC8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
