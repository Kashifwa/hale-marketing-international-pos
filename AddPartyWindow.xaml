<Window x:Class="Hale_Marketing_International.AddPartyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parties — Hale Marketing International"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#111D2B"
        FontFamily="Segoe UI"
        MinHeight="620" MinWidth="960"
        Width="1100" Height="680">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Hale Marketing International;component/PosTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <!-- top bar -->
            <RowDefinition Height="Auto"/>
            <!-- form -->
            <RowDefinition Height="*"/>
            <!-- datagrid -->
            <RowDefinition Height="28"/>
            <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ══ TOP BAR ══ -->
        <Border Grid.Row="0" Style="{StaticResource TopBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="3" Height="20" Background="{StaticResource Accent}"
                            CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock Text="PARTIES" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TxtPri}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtPartyCount" Text="  •  0 parties"
                               FontSize="12" Foreground="{StaticResource TxtSec}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Search -->
                <Border Grid.Column="1" Background="{StaticResource Bg3}" CornerRadius="4"
                        BorderBrush="{StaticResource Border1}" BorderThickness="1"
                        Width="260" HorizontalAlignment="Center" Height="32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⌕" Foreground="{StaticResource TxtSec}" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 Padding="0,7,0,0"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TxtPri}"
                                 CaretBrush="{StaticResource Accent}"
                                 FontSize="12" VerticalAlignment="Center"
                                 Text="Search..."
                                 TextChanged="txtSearch_TextChanged"
                                 GotFocus="txtSearch_GotFocus"
                                 LostFocus="txtSearch_LostFocus"/>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnAdd"    Content="＋ Add"    Style="{StaticResource BtnPrimary}" Margin="4,0" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnUpdate" Content="✎ Update"  Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnUpdate_Click" IsEnabled="False"/>
                    <Button x:Name="BtnDelete" Content="✕ Delete"  Style="{StaticResource BtnDanger}"  Margin="4,0" Click="BtnDelete_Click" IsEnabled="False"/>
                    <Button x:Name="BtnSaveAll" Content="Save All" Style="{StaticResource BtnGhost}"   Margin="4,0" Click="BtnSaveAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ FORM ══ -->
        <Border Grid.Row="1" Style="{StaticResource SectionPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Labels -->
                <TextBlock Grid.Column="0"  Text="ID"          Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="2"  Text="PARTY NAME"  Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="4"  Text="CONTACT"     Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="6"  Text="ADDRESS"     Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="8"  Text="DESCRIPTION" Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="10"  Text="TYPE"        Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="12" Text="DATE"        Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="14" Text="TIME"        Style="{StaticResource FieldLabel}"/>

                <!-- Inputs -->
                <TextBox    x:Name="txtId"          Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource PosInput}" IsReadOnly="True"/>

                <TextBox    x:Name="txtPartyName"   Grid.Row="1" Grid.Column="2"
                            Style="{StaticResource PosInput}"
                            Text="Party Name"
                            GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

                <TextBox    x:Name="txtContact"     Grid.Row="1" Grid.Column="4"
                            Style="{StaticResource PosInput}"
                            Text="Contact"
                            GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

                <TextBox    x:Name="txtAddress"     Grid.Row="1" Grid.Column="6"
                            Style="{StaticResource PosInput}"
                            Text="Address"
                            GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

                <TextBox x:Name="txtDescription"  Grid.Row="1" Grid.Column="8"
                         Style="{StaticResource PosInput}"
                         Text="Description"
                         GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

                <ComboBox   x:Name="cmbType"        Grid.Row="1" Grid.Column="10"
                            Style="{StaticResource PosCombo}"
                            Loaded="cmbType_Loaded"
                            SelectionChanged="cmbType_SelectionChanged">
                    <ComboBoxItem Content="Payable"/>
                    <ComboBoxItem Content="Receivable"/>
                </ComboBox>

                <DatePicker x:Name="dpDate"         Grid.Row="1" Grid.Column="12"
                            Style="{StaticResource PosDate}"/>

                <TextBox    x:Name="txtTime"        Grid.Row="1" Grid.Column="14"
                            Style="{StaticResource PosInput}" IsReadOnly="True"/>
            </Grid>
        </Border>

        <!-- ══ DATAGRID ══ -->
        <DataGrid x:Name="dgParties"
                  Grid.Row="2"
                  Style="{StaticResource PosGrid}"
                  ColumnHeaderStyle="{StaticResource PosGridHeader}"
                  RowStyle="{StaticResource PosGridRow}"
                  CellStyle="{StaticResource PosGridCell}"
                  AutoGenerateColumns="False"
                  SelectionChanged="dgParties_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="50"/>
                <DataGridTextColumn Header="NAME"        Binding="{Binding Name}"         Width="*"/>
                <DataGridTextColumn Header="TYPE"        Binding="{Binding Type}"         Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="Payable">
                                    <Setter Property="Foreground" Value="#FFB300"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="Receivable">
                                    <Setter Property="Foreground" Value="#00BFA5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="CONTACT"     Binding="{Binding Contact}"      Width="140"/>
                <DataGridTextColumn Header="ADDRESS"     Binding="{Binding Address}"      Width="220"/>
                <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}"  Width="200"/>
                <DataGridTextColumn Header="DATE"        Binding="{Binding Date}"         Width="100"/>
                <DataGridTextColumn Header="TIME"        Binding="{Binding Time}"         Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="3" Background="{StaticResource Bg0}" Padding="18,0">
            <TextBlock Text="Hale Marketing International — Parties"
                       Foreground="{StaticResource TxtMuted}" FontSize="10"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>