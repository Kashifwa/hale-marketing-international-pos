<Window x:Class="Hale_Marketing_International.ItemLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Ledger"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="MainBackground"      Color="#2C3E50"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#34495E"/>
        <SolidColorBrush x:Key="AccentBrush"         Color="#007ACC"/>
        <SolidColorBrush x:Key="TextBrush"           Color="White"/>
        <SolidColorBrush x:Key="HeaderBackground"    Color="#1F2D3A"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"           Value="4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground"     Value="{StaticResource TextBrush}"/>
            <Setter Property="Background"     Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="4"/>
            <Setter Property="Height"         Value="28"/>
            <Setter Property="Margin"         Value="4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground"     Value="{StaticResource TextBrush}"/>
            <Setter Property="Background"     Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"         Value="30"/>
            <Setter Property="Margin"         Value="4"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Foreground"     Value="{StaticResource TextBrush}"/>
            <Setter Property="Background"     Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"         Value="30"/>
            <Setter Property="Margin"         Value="4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Background"  Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding"     Value="6,3"/>
            <Setter Property="Margin"      Value="4"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Height"      Value="33"/>
            <Setter Property="Width"       Value="110"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground"            Value="White"/>
            <Setter Property="RowBackground"         Value="#34495E"/>
            <Setter Property="AlternatingRowBackground" Value="#3B4B63"/>
            <Setter Property="BorderBrush"           Value="{StaticResource AccentBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="ColumnHeaderHeight"    Value="35"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Background"  Value="{StaticResource HeaderBackground}"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="{StaticResource MainBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Item Ledger"
                   FontSize="26" FontWeight="Bold"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Left"/>

        <!-- FILTER BAR -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Product Search -->
                <StackPanel>
                    <TextBlock Text="Search Product:" FontWeight="Bold" Foreground="Black"/>
                    <ComboBox x:Name="CmbProduct"
                              IsEditable="True"
                              DisplayMemberPath="ProductName"
                              SelectionChanged="CmbProduct_SelectionChanged"
                              KeyUp="CmbProduct_KeyUp"/>
                </StackPanel>

                <!-- From Date -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="From Date:" FontWeight="Bold" Foreground="Black"/>
                    <DatePicker x:Name="DtFrom" Foreground="Black"/>
                </StackPanel>

                <!-- To Date -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="To Date:" FontWeight="Bold" Foreground="Black"/>
                    <DatePicker x:Name="DtTo" Foreground="Black"/>
                </StackPanel>

                <!-- Show Button -->
                <Button Grid.Column="3"
                        Content="Show Ledger"
                        Margin="8,18,4,0"
                        Click="BtnShowLedger_Click"/>

                <!-- Print Button -->
                <Button Grid.Column="4"
                        Content="Print"
                        Margin="4,18,0,0"
                        Click="BtnPrint_Click"/>
            </Grid>
        </Border>

        <!-- SELECTED PRODUCT INFO BAR -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Background="{StaticResource SecondaryBackground}">
            <StackPanel>

                <!-- Product detail strip -->
                <Border Background="{StaticResource HeaderBackground}"
                        CornerRadius="4"
                        Padding="10,6"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Product: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtProductName" Text="-"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Code: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtProductCode" Text="-"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="Purchase Price: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtPurchasePrice" Text="-"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <TextBlock Text="Sale Price: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtSalePrice" Text="-"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Data Grid -->
                <DataGrid x:Name="DgItemLedger"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeight="30"
                          MaxHeight="460">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"         Binding="{Binding Date}"        Width="85"/>
                        <DataGridTextColumn Header="Type"         Binding="{Binding Type}"        Width="120"/>
                        <DataGridTextColumn Header="Invoice No"   Binding="{Binding InvoiceNo}"   Width="110"/>
                        <DataGridTextColumn Header="Party Name"   Binding="{Binding PartyName}"   Width="160"/>
                        <DataGridTextColumn Header="Stock In"     Binding="{Binding StockIn}"     Width="80"/>
                        <DataGridTextColumn Header="Stock Out"    Binding="{Binding StockOut}"    Width="80"/>
                        <DataGridTextColumn Header="Balance Qty"  Binding="{Binding BalanceQty}"  Width="90"/>
                        <DataGridTextColumn Header="Rate"         Binding="{Binding Rate}"        Width="80"/>
                        <DataGridTextColumn Header="Amount"       Binding="{Binding Amount}"      Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Summary strip -->
                <Border Background="{StaticResource HeaderBackground}"
                        CornerRadius="4"
                        Padding="10,6"
                        Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Total Stock In: "  FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotalIn"  Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Total Stock Out: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotalOut" Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="Closing Balance: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtClosingBalance" Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <TextBlock Text="Net Amount: " FontWeight="Bold"/>
                            <TextBlock x:Name="TxtNetAmount" Text="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <TextBlock Grid.Row="4"
                   Text="Hale Marketing International - Item Ledger"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>