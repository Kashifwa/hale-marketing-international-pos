<Window x:Class="Hale_Marketing_International.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invoice Print Preview"
        Height="800" Width="900"
        WindowStartupLocation="CenterOwner"
        MinWidth="700" MinHeight="500">

    <Grid>
        <DockPanel>

            <!-- Toolbar -->
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Top"
                        Background="#F3F3F3"
                        Margin="8,8,8,8">
                <Button x:Name="BtnPrint"
                        Content="🖨 Print"
                        Width="100"
                        Margin="0,0,8,0"
                        Click="BtnPrint_Click"/>
                <Button x:Name="BtnPrintDirect"
                        Content="Print (Direct)"
                        Width="120"
                        Margin="0,0,8,0"
                        Click="BtnPrintDirect_Click"/>
                <Separator Width="10"/>
                <Button Content="Close"
                        Width="80"
                        Click="BtnClose_Click"/>
                <TextBlock VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="Gray">
                    Use Print → to choose printer / page settings
                </TextBlock>
            </StackPanel>

            <!-- Real page-by-page viewer -->
            <DocumentViewer x:Name="DocViewer"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
        </DockPanel>
    </Grid>
</Window>
