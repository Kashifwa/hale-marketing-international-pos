<!--
    BackupSyncWindow.xaml
    Opened from the "☁ Backup & Sync" sidebar button inside MainAppWindow.
    Shows connected Google account, last backup time, and Sync Now button.
-->
<Window x:Class="Hale_Marketing_International.Views.BackupSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backup &amp; Sync"
        Width="420" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2C6FDF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A5BC8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="☁ Backup &amp; Sync"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="Your data is automatically backed up to Google Drive when you close the app."
                   TextWrapping="Wrap" FontSize="12" Foreground="#777" Margin="0,0,0,20"/>

        <!-- Google Account status -->
        <Border Grid.Row="2" Background="#F0F4FF" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Connected Google Account" FontSize="11"
                           Foreground="#555" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtEmail" Text="Not connected"
                           FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A"/>
            </StackPanel>
        </Border>

        <!-- Last backup time -->
        <Border Grid.Row="3" Background="#F7F7F7" CornerRadius="8" Padding="14,12" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Last Backup" FontSize="11" Foreground="#555" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtLastBackup" Text="Never"
                           FontSize="13" Foreground="#333"/>
            </StackPanel>
        </Border>

        <!-- Progress bar (hidden until sync) -->
        <ProgressBar Grid.Row="4" x:Name="PbSync"
                     Height="5" Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed" Margin="0,0,0,8"
                     Foreground="#2C6FDF"/>

        <!-- Status text -->
        <TextBlock Grid.Row="5" x:Name="TxtStatus"
                   FontSize="12" Foreground="#555"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Vertical">
            <Button x:Name="BtnSync" Content="🔄 Sync Now"
                    Style="{StaticResource PrimaryBtn}"
                    HorizontalAlignment="Stretch"
                    Margin="0,5,0,20"
                    Click="BtnSync_Click"/>

            <Button x:Name="BtnConnect" Content="Connect / Change Google Account"
                    Style="{StaticResource PrimaryBtn}"
                    HorizontalAlignment="Stretch"
                    Background="#555555"
                    Margin="0,0,0,160"
                    Click="BtnConnect_Click"/>
        </StackPanel>
    </Grid>
</Window>
